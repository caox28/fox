import /init.recovery.wifi.rc

on init
    start vendor.boot-qti
    setprop prepdecrypt.setpatch true

on early-fs
    write /proc/sys/walt/sched_lib_name "recovery,magiskboot,Updater,updater,update_engine_sideload"
    write /proc/sys/walt/sched_lib_mask_force 255

on fs
    wait /dev/block/platform/soc/${ro.boot.bootdevice}
    symlink /dev/block/platform/soc/${ro.boot.bootdevice} /dev/block/bootdevice
    write /proc/sys/kernel/firmware_config/force_sysfs_fallback 1
    chmod 0660 /dev/qseecom
    chown system drmrpc /dev/qseecom
    chmod 0664 /dev/ion
    chown system system /dev/ion
    mkdir /mnt/vendor 0775 shell system
    mkdir /mnt/vendor/persist 0775 shell system
    mkdir /tmp/persist 0775 shell system
    mount none /tmp/persist /mnt/vendor/persist bind rec
    install_keyring

on post-fs
    start odm.variant-script

on boot
    setprop sys.usb.config adb

on property:twrp.modules.loaded=true
    # Mount firmware for ADSP
    mkdir /firmware
    mount vfat /dev/block/bootdevice/by-name/modem${ro.boot.slot_suffix} /firmware ro
    # Load ADSP firmware for PMIC / KeyMint chain
    wait /sys/kernel/boot_adsp/ssr
    write /sys/kernel/boot_adsp/ssr 1
    wait /sys/class/power_supply/battery
    start vendor.health-default
    umount /firmware

on property:ro.crypto.state=encrypted && property:ro.boot.dynamic_partitions=true
    start odm.prepdecrypt

on property:twrp.variant.files_copied=1
    # vibratorfeature-service disabled: TW_SUPPORT_INPUT_AIDL_HAPTICS is off,
    # and service lacks android.hardware.vibrator-V1-ndk.so + libxml2.so → crash-loop
    # start odm.vibratorfeature-service
    start odm.touch_report
    # CRITICAL startup order for NXP/Thales JavaCard decrypt chain:
    # se_omapi must start BEFORE weaver (eSE APDU channel provider)
    # weaver needs se_omapi eSE channel to read Weaver key slots
    # keymint-strongbox needs weaver key + libjc_keymint symlinks
    start odm.se_omapi
    start odm.weaver-service
    start odm.keymint-strongbox

on property:crypto.ready=1
    start odm.umountvendor

on property:hwservicemanager.ready=true
    setprop sys.boot_completed 1
