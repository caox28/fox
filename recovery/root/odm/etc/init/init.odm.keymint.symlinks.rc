# Symlinks: NXP-named libs -> Thales-named libs (same binary, different filename)
# Required by: keymint-service.strongbox, weaver-service
# Confirmed via readelf -d on device binaries (BuildID match)
on early-init
    symlink /odm/lib64/libjc_keymint-thales.so          /odm/lib64/libjc_keymint3.nxp.so
    symlink /odm/lib64/libjc_keymint_transport-thales.so /odm/lib64/libjc_keymint_transport_nxp.so
    symlink /odm/lib64/ese_weaver_thales.so               /odm/lib64/ese_weaver.so
    symlink /vendor/lib64/lib_android_keymaster_keymint_utils.so /odm/lib64/lib_android_keymaster_keymint_utils_V3.so
