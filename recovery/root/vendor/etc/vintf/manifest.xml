<!--
    Vendor VINTF manifest — myron (POCO F8 Ultra / SM8850 sun)
    NOTE: android.hardware.keymaster@4.1 entry added FOR OFOX KEYMASTER DETECTION ONLY.
    OFox R11.x/R12.x Keymaster_Ver() searches for this HIDL entry to determine decrypt path.
    The actual decrypt uses KeyMint AIDL (version 3) — this entry is only for OFox parser.
    FIX: version 9.0→2.0 for libvintf@8.0 compatibility (OFox R11.3/R12.1)
    FIX: <n>→<name> per libvintf XML schema
-->
<manifest version="2.0" type="device">
    <!-- OFox keymaster version detection (HIDL legacy entry required by OFox parser) -->
    <hal format="hidl">
        <name>android.hardware.keymaster</name>
        <transport>hwbinder</transport>
        <version>4.1</version>
        <interface>
            <name>IKeymasterDevice</name>
            <instance>default</instance>
        </interface>
    </hal>
    <!-- Actual KeyMint AIDL (used for real decrypt) -->
    <hal format="aidl">
        <name>android.hardware.security.keymint</name>
        <version>3</version>
        <fqname>IKeyMintDevice/default</fqname>
    </hal>
    <hal format="aidl">
        <name>android.hardware.security.keymint</name>
        <version>3</version>
        <fqname>IRemotelyProvisionedComponent/default</fqname>
    </hal>
    <hal format="aidl">
        <name>android.hardware.gatekeeper</name>
        <fqname>IGatekeeper/default</fqname>
    </hal>
    <hal format="aidl">
        <name>android.hardware.secure_element</name>
        <fqname>ISecureElement/eSE1</fqname>
    </hal>
</manifest>
